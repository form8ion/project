{
  "name": "@form8ion/project",
  "description": "opinionated scaffolder for new projects",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "module",
  "engines": {
    "node": "^22.22.2 || >=24.15"
  },
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "contributors": [
    "Trevor Richardson <npm@trevorrichardson.me> (https://trevorrichardson.me)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/form8ion/project.git"
  },
  "bugs": "https://github.com/form8ion/project/issues",
  "homepage": "https://www.npmjs.com/package/@form8ion/project",
  "funding": {
    "url": "https://github.com/sponsors/travi"
  },
  "exports": "./lib/index.js",
  "main": "./lib/index.js",
  "scripts": {
    "pretest": "run-s build",
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "lint:engines": "ls-engines",
    "lint:gherkin": "gplint --config .gplintrc.json",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:lockfile": "lockfile-lint",
    "lint:md": "remark --quiet . --frail",
    "lint:peer": "npm ls >/dev/null",
    "lint:publish": "publint --strict",
    "test:unit": "run-s 'test:unit:base -- --coverage'",
    "test:unit:base": "NODE_ENV=test DEBUG=any vitest run src/",
    "test:integration": "run-s 'test:integration:base -- --profile noWip'",
    "pretest:integration:base": "run-s build",
    "test:integration:base": "NODE_OPTIONS=--enable-source-maps cucumber-js test/integration",
    "test:integration:focus": "run-s 'test:integration:base -- --profile focus'",
    "test:integration:wip": "run-s 'test:integration:base -- --profile wip'",
    "build": "run-s clean build:*",
    "build:js": "rollup -c",
    "clean": "rimraf lib/",
    "pregenerate:md": "run-s build",
    "generate:md": "remark . --output",
    "prepack": "run-s build",
    "prepare": "husky",
    "watch": "run-s 'build:js -- --watch'"
  },
  "files": [
    "lib/",
    "src/",
    "templates/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.18.0+sha512.4faecce0be70366d1c67b1012c4adc1246354a6cc45bf589f92003073b05518d547403df1475c542d67a4845e22b4fafcd7cac0af02c7a96cc6814f09eb003fb",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@form8ion/core": "^5.0.0-beta.6",
    "@form8ion/git": "^3.0.0-beta.2",
    "@form8ion/mise": "^1.1.1",
    "@form8ion/readme": "^4.0.0-beta.2",
    "@hapi/hoek": "^11.0.2",
    "deepmerge": "^4.2.2",
    "execa": "^9.5.1",
    "filedirname": "^3.0.0",
    "git-url-parse": "^16.1.0",
    "joi": "^18.0.0",
    "mustache": "4.2.0",
    "simple-git": "^3.16.0",
    "spdx-license-list": "6.11.0",
    "word-wrap": "^1.2.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "13.0.0",
    "@form8ion/commitlint-config": "2.0.17",
    "@form8ion/eslint-config": "7.1.0-beta.1",
    "@form8ion/eslint-config-cucumber": "1.4.1",
    "@form8ion/eslint-config-vitest": "1.1.0",
    "@form8ion/remark-lint-preset": "6.0.7",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@travi/any": "3.3.0",
    "@vitest/coverage-v8": "4.1.9",
    "chai": "6.2.2",
    "cz-conventional-changelog": "3.3.0",
    "debug": "4.4.3",
    "gplint": "2.5.2",
    "husky": "9.1.7",
    "lockfile-lint": "5.0.0",
    "ls-engines": "0.10.1",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-heading-range": "4.0.0",
    "mdast-zone": "6.1.0",
    "mock-fs": "5.5.0",
    "npm-run-all2": "9.0.2",
    "publint": "0.3.21",
    "remark-cli": "12.0.1",
    "remark-toc": "9.0.0",
    "remark-usage": "11.0.1",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "rollup-plugin-auto-external": "2.0.0",
    "sinon": "22.0.0",
    "testdouble": "3.20.2",
    "unist-util-find": "3.0.0",
    "vitest": "4.1.9",
    "vitest-when": "0.10.0"
  }
}
